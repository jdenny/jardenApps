<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_margin="10sp"
    tools:context=".GameActivity">

    <!-- android:visibility="gone" -->

    <LinearLayout
        android:id="@+id/hostLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/hostControlBackground"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:theme="@style/ThemeOverlay.AppCompat.ActionBar" />

        <TextView
            android:id="@+id/hostPromptView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/codswallop"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/nextQuestionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next_question"
                android:visibility="gone"
                android:textSize="20sp" />
            <!--
            <Button
                android:id="@+id/broadcastHostButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/broadcastHostAddress"
                android:textSize="20sp" />
                -->
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="cursive"
        android:text="@string/codswallop"
        android:textSize="30sp" />

    <TextView
        android:id="@+id/playerPromptView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20sp"
        android:textSize="20sp" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>